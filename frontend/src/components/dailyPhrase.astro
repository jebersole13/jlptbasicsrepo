---
import {idiomsObject} from '../lib/phrase'


const startDate = new Date('2026-02-23').getTime()
const today = Date.now()
const daysSinceStart = Math.floor((today -startDate) / (1000 * 60 * 60 * 24))
const currentIndex = Math.min(daysSinceStart % 31,30)
const todaysIdiom = idiomsObject[currentIndex]
---


<div class="flex justify-center md:m-20">
    
    <div class=" sm:w-96  bg-gray-200 border-2 text-center md: p-4 sm:p-2 rounded-2xl ">
    <div class=" space-y-5">
    <h1 class=" md:text-4xl font-bold sm:text-lg "> Daily Idiom </h1>
    
    
    <h1 class="md:text-4xl  sm:text-lg font-semibold ">{todaysIdiom.phrase}</h1>
        <h2 class="md:text-3xl  sm:text-lg font-medium ">{todaysIdiom.hiragana}</h2>
    
    </div>
    
    </div>
</div>
