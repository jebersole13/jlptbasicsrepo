---

import Layout from '../../layouts/Layout.astro';
import { apiLogin } from '../../lib/auth';

let errorMessage = '';

if (Astro.locals.isAuthenticated) {
    return Astro.redirect('/studypage/progressdashboard');
}

if (Astro.request.method === 'POST') {
    try {
        const formData = await Astro.request.formData();
        const email = formData.get('email')?.toString().trim().toLowerCase();
        const password = formData.get('password')?.toString();

        if (!email || !password) {
            errorMessage = 'Email and password are required.';
        } else {
            const result = await apiLogin({ email, password }, Astro.cookies);
            return Astro.redirect(result.is_first_login ? '/studypage/settings' : '/studypage/progressdashboard');
        }
    } catch (error: any) {
        // Never expose raw server errors to the user
        errorMessage = error.status === 401
            ? 'Invalid email or password.'
            : 'Login failed. Please try again.';
    }
}
---

<Layout>
<div class='p-10 md:m-10'>
    <h1 class="text-center font-bold text-5xl">Login</h1>

    {errorMessage && (
        <div class="mt-4 p-4 bg-red-100 text-red-700 rounded-md" role="alert">
            {errorMessage}
        </div>
    )}

    <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
        <div class="bg-pink-200 py-8 px-4 shadow-2xl rounded-lg sm:px-10">
            <form method="POST">
                <div class="mt-5">
                    <label for="email" class="block text-sm font-medium text-gray-700">Email</label>
                    <input
                        type="email"
                        name="email"
                        id="email"
                        required
                        autocomplete="email"
                        class="mt-1 bg-white appearance-none block w-full px-3 py-2 border border-gray-700 rounded"
                        placeholder="your@email.com"
                    />
                </div>

                <div class="mt-5">
                    <label for="password" class="block text-sm font-medium text-gray-700">Password</label>
                    <input
                        type="password"
                        name="password"
                        id="password"
                        required
                        autocomplete="current-password"
                        class="mt-1 bg-white appearance-none block w-full px-3 py-2 border border-gray-700 rounded"
                        placeholder="Enter your password"
                    />
  <input type="checkbox" name="" id=""> Show Password

                </div>

                <div class="mt-7">
                    <button
                        type="submit"
                        class="bg-blue-600 hover:bg-blue-500 active:bg-indigo-700 text-white w-full justify-center py-2 px-4 border text-sm font-medium rounded-md cursor-pointer transition duration-300"
                    >
                        Sign In
                    </button>
                </div>

                <div class="mt-5">
                    <p class="text-gray-700 text-lg">Don't have an account?</p>
                    <a class="text-blue-800 hover:text-blue-950 text-lg" href="/registration">Register here</a>
                </div>

                <div class="mt-5">
                    <p class="text-gray-700 text-lg">Forgot your password?</p>
                    <a class="text-blue-800 hover:text-blue-950 text-lg" href="/forgot">Reset password</a>
                </div>
            </form>
        </div>
    </div>
</div>
</Layout>
<script  src="../../lib/hideShow.ts">
