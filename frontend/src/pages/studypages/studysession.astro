---
import StudentLayout from "../../../layouts/StudentLayout.astro";
import { studyChoiceOptions, studentChoiceSave } from "../../../lib/api";
import { AuthError } from "../../../lib/auth";

let successMessage = '';
let errorMessage = '';

if (Astro.request.method === 'POST') {
    try {
        const formData = await Astro.request.formData();
        const topic = formData.get('topic')?.toString();
        const duration = parseInt(formData.get('duration')?.toString() ?? '0');
        const notes = formData.get('notes')?.toString() ?? '';

        if (!topic) {
            errorMessage = 'No topic selected.';
        } else {
            await studentChoiceSave({ topic, duration, notes }, Astro.cookies);
            successMessage = 'Study session saved!';
        }
    } catch (error) {
        if (error instanceof AuthError) throw error;
        errorMessage = error instanceof Error ? error.message : 'Failed to save session.';
    }
}

let topics: [string, string][] = [];
try {
    topics = await studyChoiceOptions(Astro.cookies);
} catch (error) {
    if (error instanceof AuthError) throw error;
    errorMessage = 'Failed to load topics.';
}
---

<StudentLayout>
<div class="max-w-2xl mx-auto p-6">

    {successMessage && (
        <div class="bg-green-100 text-green-800 p-4 rounded mb-6" role="status">
            {successMessage}
            <a href="/studypage/progressdashboard" class="ml-2 underline text-green-900">Back to dashboard</a>
        </div>
    )}

    {errorMessage && (
        <div class="bg-red-100 text-red-800 p-4 rounded mb-6" role="alert">
            {errorMessage}
        </div>
    )}

    <!-- Step 1: Topic selection -->
    <div id="topic-selection" class="space-y-3">
        <h1 class="text-3xl font-semibold text-center mb-8">What are you studying today?</h1>
        {topics.map(([key, label]) => (
            <button
                class="w-full px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-lg font-medium transition-colors topic-btn"
                data-topic={key}
                type="button"
            >
                {label}
            </button>
        ))}
    </div>

    <!-- Step 2: Timer mode -->
    <div id="timer-options" class="hidden mt-8 space-y-3">
        <h2 class="text-xl font-semibold mb-2">Choose a timer mode</h2>
        <button class="w-full px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg transition-colors timer-option" data-type="freerun" type="button">Free Run</button>
        <button class="w-full px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg transition-colors timer-option" data-type="set" type="button">Set Time</button>
        <button class="w-full px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg transition-colors timer-option" data-type="pomodoro" type="button">Pomodoro (50 min / 10 min break)</button>
        <button id="back-to-topics" class="w-full px-6 py-3 border border-gray-300 rounded-lg text-gray-600 hover:bg-gray-50 transition-colors" type="button">← Back</button>
    </div>

    <!-- Step 2a: Set time -->
    <div id="set-time-input" class="hidden mt-6 space-y-4">
        <h3 class="text-lg font-semibold">Set Duration</h3>
        <div class="flex gap-4">
            <label class="flex flex-col text-sm">Hours
                <input type="number" id="hours-input" min="0" max="23" value="0" class="mt-1 w-20 px-3 py-2 border rounded" />
            </label>
            <label class="flex flex-col text-sm">Minutes
                <input type="number" id="minutes-input" min="0" max="59" value="30" class="mt-1 w-20 px-3 py-2 border rounded" />
            </label>
        </div>
        <button id="start-set-timer" class="px-6 py-3 bg-green-600 hover:bg-green-700 text-white rounded-lg transition-colors" type="button">Start Timer</button>
    </div>

    <!-- Step 2b: Pomodoro -->
    <div id="pomodoro-input" class="hidden mt-6 space-y-4">
        <h3 class="text-lg font-semibold">Pomodoro Sessions</h3>
        <label class="flex flex-col text-sm">How many sessions?
            <input type="number" id="pomodoro-sessions" min="1" max="10" value="1" class="mt-1 w-20 px-3 py-2 border rounded" />
        </label>
        <button id="start-pomodoro" class="px-6 py-3 bg-green-600 hover:bg-green-700 text-white rounded-lg transition-colors" type="button">Start Pomodoro</button>
    </div>

    <!-- Step 3: Active timer -->
    <div id="timer-display" class="hidden mt-8 text-center space-y-4">
        <div class="text-6xl font-bold tabular-nums" id="timer-text">00:00:00</div>
        <div class="text-gray-500" id="timer-status"></div>
        <div class="flex justify-center gap-4">
            <button id="timer-start" class="px-6 py-3 bg-green-600 hover:bg-green-700 text-white rounded-lg transition-colors" type="button">Start</button>
            <button id="timer-pause" class="hidden px-6 py-3 bg-yellow-500 hover:bg-yellow-600 text-white rounded-lg transition-colors" type="button">Pause</button>
            <button id="timer-stop" class="px-6 py-3 bg-red-600 hover:bg-red-700 text-white rounded-lg transition-colors" type="button">Stop &amp; Save</button>
        </div>
    </div>

    <!-- Step 4: Save form -->
    <div id="save-form" class="hidden mt-8">
        <form method="POST" class="space-y-4">
            <input type="hidden" name="topic" id="selected-topic" />
            <input type="hidden" name="duration" id="final-duration" />
            <div>
                <label for="notes" class="block text-lg font-semibold mb-2">What did you learn?</label>
                <textarea
                    name="notes"
                    id="notes"
                    rows="6"
                    class="w-full px-4 py-2 border rounded-lg resize-y"
                    placeholder="Optional: write notes about what you studied..."
                ></textarea>
            </div>
            <p class="text-sm text-gray-500">
                Time studied: <span id="duration-display" class="font-medium text-gray-700"></span>
            </p>
            <button type="submit" class="w-full px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-lg font-medium transition-colors">
                Save Session
            </button>
        </form>
    </div>
</div>

<script>
    import { initTimerPage } from '../../../lib/timer';
    initTimerPage();
</script>
</StudentLayout>