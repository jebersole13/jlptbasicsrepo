---
import "../styles/global.css";
import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";

const {
	title = 'JLPT Countdown',
	description = 'An application to help you track your JLPT goals',
	image ="https://jlptcountdown.com/time.png"
} = Astro.props

---

<!doctype html>
<html lang="en" class=" scroll-smooth light" data-theme="light">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/time.gif" />
		<link rel="icon" href="/" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<!--ogs -->
 		<meta property="og:title" content={title} />
    	<meta property="og:description" content={description} />
    	<meta property="og:type" content="website" />
	    <meta property='og:image' content={image}/>
	    <meta property='og:image.alt' content={title}/>
		<meta property="og:url" content="https://jlptcountdown.com" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<!--twitter cards -->

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
    	<meta name="twitter:description" content={description} />
		<meta name='twitter:image' content={image}/>
		<meta name='twitter:image.alt' content={title}/>

		<title>{title}</title>
	</head>
	<body      class="flex flex-col h-full w-full min-h-screen relative content-center bg-[url(/cherry2.gif)] dark:bg-[url(/fatbeard-final-shirakawa.gif)] bg-cover  ">
<Navbar/>

		<main class="grow space-y-5">
		<slot />
		</main>
		<Footer/>
	</body>
</html>
